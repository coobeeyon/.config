font-family = JetBrainsMono
theme = Builtin Solarized Dark
gtk-titlebar = false

# Make split dividers visible on light background
split-divider-color = #d65d0e

# ============================================================
# Keybindings — minimal config for use with zellij
# Ghostty only handles: font size, copy/paste, fullscreen, config
# Everything else is unbound so zellij (alt-based) has no conflicts
# ============================================================

# --- Font size ---
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size

# --- Copy / Paste ---
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_selection

# --- Window ---
keybind = alt+f4=close_window
keybind = ctrl+enter=toggle_fullscreen

# --- Config ---
keybind = ctrl+comma=open_config
keybind = ctrl+shift+comma=reload_config

# --- Unbind all other defaults ---
keybind = ctrl+a=unbind
keybind = ctrl+shift+a=unbind
keybind = ctrl+t=unbind
