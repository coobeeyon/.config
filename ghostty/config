font-family = JetBrainsMono
theme = Gruvbox Light

# ============================================================
# Keybindings: ghostty owns Ctrl, i3 owns Ctrl+Shift
# Exceptions: copy/paste stay Ctrl+Shift (Ctrl+C/V are terminal signals)
# Source: ghostty +list-keybinds defaults + custom (2026-03-30)
# ============================================================

# --- Font size ---
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# --- Copy / Paste (Ctrl+Shift exception — Ctrl+C/V are terminal signals) ---
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_selection
keybind = copy=copy_to_clipboard
keybind = paste=paste_from_clipboard

# --- Selection ---
keybind = ctrl+a=select_all
keybind = shift+arrow_up=adjust_selection:up
keybind = shift+arrow_down=adjust_selection:down
keybind = shift+arrow_left=adjust_selection:left
keybind = shift+arrow_right=adjust_selection:right

# --- Scrolling ---
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom

# --- Tabs (all Ctrl) ---
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_tab:this
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+page_down=next_tab
keybind = ctrl+page_up=previous_tab
keybind = ctrl+digit_1=goto_tab:1
keybind = ctrl+digit_2=goto_tab:2
keybind = ctrl+digit_3=goto_tab:3
keybind = ctrl+digit_4=goto_tab:4
keybind = ctrl+digit_5=goto_tab:5
keybind = ctrl+digit_6=goto_tab:6
keybind = ctrl+digit_7=goto_tab:7
keybind = ctrl+digit_8=goto_tab:8
keybind = ctrl+digit_9=goto_tab:9

# --- Splits: create (Ctrl, not Ctrl+Shift) ---
keybind = ctrl+d=new_split:down
keybind = ctrl+r=new_split:right

# --- Splits: navigate ---
keybind = ctrl+.=goto_split:next
keybind = ctrl+shift+.=goto_split:previous
keybind = ctrl+alt+arrow_up=goto_split:up
keybind = ctrl+alt+arrow_down=goto_split:down
keybind = ctrl+alt+arrow_left=goto_split:left
keybind = ctrl+alt+arrow_right=goto_split:right

# --- Splits: resize ---
keybind = ctrl+alt+shift+arrow_up=resize_split:up,10
keybind = ctrl+alt+shift+arrow_down=resize_split:down,10
keybind = ctrl+alt+shift+arrow_left=resize_split:left,10
keybind = ctrl+alt+shift+arrow_right=resize_split:right,10

# --- Window ---
keybind = ctrl+n=new_window
keybind = alt+f4=close_window
keybind = ctrl+enter=toggle_fullscreen

# --- Config ---
keybind = ctrl+comma=open_config
keybind = ctrl+shift+comma=reload_config

# --- Debug ---
keybind = ctrl+alt+shift+j=write_screen_file:open
